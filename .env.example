# ─────────────────────────────────────────────────────────────────────────────
# twikit-mcp — Environment Variables
#
# Authenticate by copying two cookies from a browser already logged in to x.com
# (DevTools → Application/Storage → Cookies → https://x.com): auth_token and ct0.
#
# 🔐 Treat these like a password — they grant access to your account. Do not
#    commit them. They rotate when you log out of that browser session.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: the auth_token cookie value from x.com
TWIKIT_AUTH_TOKEN=

# REQUIRED: the ct0 cookie value from x.com
TWIKIT_CT0=

# Optional: language header (default: en-US)
# TWIKIT_LANGUAGE=en-US

# Optional: proxy, e.g. http://user:pass@host:port
# TWIKIT_PROXY=

# Optional: rate limiting is ON by default. Set to off / 0 / false to disable.
# TWIKIT_MCP_RATE_LIMIT=on

# Optional: max tool calls per minute (default: 30)
# TWIKIT_MCP_RATE_LIMIT_PER_MINUTE=30
